generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model DaireSahibi {
  id             String             @id @default(cuid())
  ad             String
  soyad          String
  tcKimlik       String             @unique
  telefon        String
  email          String?
  notlar         String?
  sifre          String?
  olusturmaTar   DateTime           @default(now())
  konutlar       Konut[]
  bakimYorumlari BakimTalebiYorum[]
  belgeler       Belge[]
}

model Konut {
  id             String        @id @default(cuid())
  blok           String
  katNo          Int
  daireNo        String        @unique
  tip            String
  metrekare      Float
  kiraBedeli     Float
  durum          String        @default("Bos")
  ozellikler     String?
  etap           Int           @default(1)
  daireSahibiId  String?
  daireSahibi    DaireSahibi?  @relation(fields: [daireSahibiId], references: [id])
  olusturmaTar   DateTime      @default(now())
  sozlesmeler     Sozlesme[]
  bakimTalepleri  BakimTalebi[]
  belgeler        Belge[]
  aidatlar        Aidat[]
  servisFaturalari ServisFaturasi[]
  teslimRaporlari TeslimRaporu[]
}

model Ogrenci {
  id             String        @id @default(cuid())
  ad             String
  soyad          String
  tcKimlik       String?       @unique
  ogrenciNo      String?
  universite     String?
  bolum          String?
  telefon        String
  email          String?       @unique
  acilKisi       String?
  acilTelefon    String?
  notlar         String?
  sifre          String?
  cinsiyet       String?
  kimlikBelgesi  String?
  ogrenciBelgesi String?
  olusturmaTar   DateTime      @default(now())
  rol            String        @default("Aktif") // "Potansiyel" | "Pasif" | "Aktif"
  sozlesmeler     Sozlesme[]
  bakimTalepleri  BakimTalebi[]
  teslimRaporlari TeslimRaporu[]
  turnikeLoglari  TurnikeLog[]
  turnikeEngeli   TurnikeEngel?
  gunlukOdemeler  GunlukOdeme[]
}

model Sozlesme {
  id              String   @id @default(cuid())
  sozlesmeNo      String   @unique
  konutId         String
  konut           Konut    @relation(fields: [konutId], references: [id])
  ogrenciId       String
  ogrenci         Ogrenci  @relation(fields: [ogrenciId], references: [id])
  baslangicTarihi DateTime
  bitisTarihi     DateTime
  aylikKira       Float
  depozito        Float
  kiraOdemGunu    Int      @default(1)
  ozelSartlar     String?
  durum           String   @default("Aktif")
  imzaTarihi      DateTime @default(now())
  olusturmaTar    DateTime @default(now())
  odemeler        Odeme[]
  onaylar         SozlesmeOnay[]
  oda             String?
}

model Odeme {
  id           String   @id @default(cuid())
  sozlesmeId   String
  sozlesme     Sozlesme @relation(fields: [sozlesmeId], references: [id])
  tutar        Float
  tip          String
  odenmeTarihi DateTime
  aciklama     String?
  olusturmaTar DateTime @default(now())
}

model SozlesmeOnay {
  id          String   @id @default(cuid())
  sozlesmeId  String
  sozlesme    Sozlesme @relation(fields: [sozlesmeId], references: [id])
  onaylayan   String   // "KiralamaSorumlusu" | "Muhasebeci" | "Admin"
  onaylayanId String
  onaylayanAd String
  tarih       DateTime @default(now())

  @@unique([sozlesmeId, onaylayan])
}

model Tedarikci {
  id           String   @id @default(cuid())
  ad           String
  telefon      String
  email        String?
  kategori     String
  notlar       String?
  olusturmaTar DateTime @default(now())
}

model Gider {
  id           String   @id @default(cuid())
  baslik       String
  tutar        Float
  kategori     String
  tarih        DateTime
  aciklama     String?
  olusturmaTar DateTime @default(now())
}

model BakimTalebi {
  id            String             @id @default(cuid())
  baslik        String
  aciklama      String
  durum         String             @default("Bekliyor")
  oncelik       String             @default("Normal")
  olusturmaTar  DateTime           @default(now())
  tamamlanmaTar DateTime?
  ogrenciId     String
  ogrenci       Ogrenci            @relation(fields: [ogrenciId], references: [id])
  konutId       String
  konut         Konut              @relation(fields: [konutId], references: [id])
  yorumlar         BakimTalebiYorum[]
  servisFaturalari ServisFaturasi[]
}

model BakimTalebiYorum {
  id            String       @id @default(cuid())
  icerik        String
  yazarTip      String       // "Admin" | "EvSahibi"
  yazarId       String
  yazarAd       String
  olusturmaTar  DateTime     @default(now())
  bakimTalebiId String
  bakimTalebi   BakimTalebi  @relation(fields: [bakimTalebiId], references: [id])
  daireSahibiId String?
  daireSahibi   DaireSahibi? @relation(fields: [daireSahibiId], references: [id])
}

model Belge {
  id            String      @id @default(cuid())
  ad            String
  tip           String      @default("Diger")
  dosyaYolu     String
  olusturmaTar  DateTime    @default(now())
  yukleyenTip   String      // "Admin" | "EvSahibi"
  yukleyenId    String
  konutId       String
  konut         Konut       @relation(fields: [konutId], references: [id])
  daireSahibiId String?
  daireSahibi   DaireSahibi? @relation(fields: [daireSahibiId], references: [id])
}

model KullaniciIzin {
  id           String   @id @default(cuid())
  kullaniciTip String   // "Kiraci" | "EvSahibi"
  kullaniciId  String
  izinler      String   // JSON: { sayfalar: string[], eylemler: string[] }
  guncelleTar  DateTime @default(now())

  @@unique([kullaniciTip, kullaniciId])
}

model Duyuru {
  id       String   @id @default(cuid())
  baslik   String
  icerik   String
  tarih    DateTime @default(now())
  hedef    String   @default("Tumu")
  yayinda  Boolean  @default(true)
}

// ─── Muhasebe Modülleri ────────────────────────────────────────────────────────

model Aidat {
  id           String   @id @default(cuid())
  konutId      String
  konut        Konut    @relation(fields: [konutId], references: [id])
  yil          Int
  ay           Int
  tutar        Float
  durum        String   @default("Bekliyor")
  odemeTarihi  DateTime?
  aciklama     String?
  olusturmaTar DateTime @default(now())
}

model ServisFaturasi {
  id            String      @id @default(cuid())
  konutId       String
  konut         Konut       @relation(fields: [konutId], references: [id])
  bakimTalebiId String?
  bakimTalebi   BakimTalebi? @relation(fields: [bakimTalebiId], references: [id])
  baslik        String
  tutar         Float
  kategori      String
  tarih         DateTime
  durum         String      @default("Bekliyor")
  odemeTarihi   DateTime?
  dosyaYolu     String?
  aciklama      String?
  olusturmaTar  DateTime    @default(now())
}

model TeslimRaporu {
  id            String   @id @default(cuid())
  konutId       String
  konut         Konut    @relation(fields: [konutId], references: [id])
  ogrenciId     String?
  ogrenci       Ogrenci? @relation(fields: [ogrenciId], references: [id])
  tip           String
  tarih         DateTime
  durumNotu     String?
  hasarlar      String?
  toplamTutar   Float    @default(0)
  dosyaYolu     String?
  onaylandi     Boolean  @default(false)
  olusturmaTar  DateTime @default(now())
}

model TurnikeLog {
  id           String   @id @default(cuid())
  ogrenciId    String
  ogrenci      Ogrenci  @relation(fields: [ogrenciId], references: [id])
  yon          String
  zaman        DateTime @default(now())
  kapi         String   @default("Ana Kapi")
  engellendi   Boolean  @default(false)
  aciklama     String?
}

model TurnikeEngel {
  id           String   @id @default(cuid())
  ogrenciId    String   @unique
  ogrenci      Ogrenci  @relation(fields: [ogrenciId], references: [id])
  neden        String
  engelleyen   String
  tarih        DateTime @default(now())
  aktif        Boolean  @default(true)
}

model Mesaj {
  id           String       @id @default(cuid())
  gonderen     String
  gonderenTip  String
  konu         String
  icerik       String
  olusturmaTar DateTime     @default(now())
  alicilar     MesajAlici[]
}

model MesajAlici {
  id        String  @id @default(cuid())
  mesajId   String
  mesaj     Mesaj   @relation(fields: [mesajId], references: [id])
  alici     String
  aliciTip  String
  okundu    Boolean @default(false)
  okunmaTar DateTime?
}

model GunlukOdeme {
  id            String   @id @default(cuid())
  ogrenciId     String?
  ogrenci       Ogrenci? @relation(fields: [ogrenciId], references: [id])
  ogrenciAd     String
  konutNo       String?
  tutar         Float
  tip           String
  odenmeTarihi  DateTime
  banka         String?
  aciklama      String?
  eslestirildi  Boolean  @default(false)
  importTarihi  DateTime @default(now())
  importDosya   String?
}

// ─── Kiralama CRM ────────────────────────────────────────────────────────────

model PotansiyelMusteri {
  id            String   @id @default(cuid())
  ad            String
  soyad         String
  telefon       String
  email         String?
  kaynak        String   @default("Manuel")
  durum         String   @default("Yeni")
  ilgiTip       String?
  butce         Float?
  notlar        String?
  atananAd      String?
  olusturmaTar  DateTime @default(now())
  guncellemeTar DateTime @updatedAt

  ogrenciId  String?  @unique
  turlar     DaireTuru[]
  gorusmeler TelefonGorusmesi[]
  davetler   DavetLinki[]
}

model DaireTuru {
  id           String            @id @default(cuid())
  musteriId    String
  musteri      PotansiyelMusteri @relation(fields: [musteriId], references: [id])
  konutId      String?
  daireNo      String?
  tarih        DateTime
  sonuc        String            @default("Belirsiz")
  notlar       String?
  yapanAd      String
  olusturmaTar DateTime          @default(now())
}

model TelefonGorusmesi {
  id           String            @id @default(cuid())
  musteriId    String
  musteri      PotansiyelMusteri @relation(fields: [musteriId], references: [id])
  tarih        DateTime
  sure         Int               @default(0)
  yon          String            @default("Giden")
  ozet         String?
  sonuc        String            @default("Belirsiz")
  arayanAd     String
  olusturmaTar DateTime          @default(now())
}

model KiralamaTemsilci {
  id           String    @id @default(cuid())
  ad           String
  soyad        String
  telefon      String
  email        String    @unique
  rol          String    @default("Temsilci")
  aktif        Boolean   @default(true)
  hedef        Int       @default(0)
  komisyonOran Float     @default(0)
  notlar       String?
  olusturmaTar DateTime  @default(now())

  hakedisler Hakedis[]
}

model Hakedis {
  id           String           @id @default(cuid())
  temsilciId   String
  temsilci     KiralamaTemsilci @relation(fields: [temsilciId], references: [id])
  ay           Int
  yil          Int
  sozlesmeNo   String?
  kiraciAd     String?
  kiraTutar    Float            @default(0)
  komisyon     Float            @default(0)
  bonus        Float            @default(0)
  toplam       Float            @default(0)
  odendi       Boolean          @default(false)
  aciklama     String?
  olusturmaTar DateTime         @default(now())
}

model DavetLinki {
  id           String             @id @default(cuid())
  musteriId    String?
  musteri      PotansiyelMusteri? @relation(fields: [musteriId], references: [id])
  email        String
  ad           String
  soyad        String
  token        String             @unique
  konutId      String?
  onerilenKira Float?
  durum        String             @default("Bekliyor")
  gonderiTar   DateTime           @default(now())
  sonlanmaTar  DateTime?
  kabulTar     DateTime?
}

model KiralamaTalepOnay {
  id           String   @id @default(cuid())
  kiraciAd     String
  kiraciEmail  String?
  konutId      String?
  konutNo      String?
  kiraTutar    Float
  aidat        Float    @default(0)
  komisyon     Float    @default(0)
  durum        String   @default("BekleyenOnay")
  muhasebeNot  String?
  idareNot     String?
  gonderenId   String?
  olusturmaTar DateTime @default(now())
}

// ─── Personel Kullanıcılar ─────────────────────────────────────────────────────

model Kullanici {
  id           String   @id @default(cuid())
  ad           String
  soyad        String
  email        String   @unique
  sifre        String
  rol          String
  telefon      String?
  aktif        Boolean  @default(true)
  notlar       String?
  sonGiris     DateTime?
  olusturmaTar DateTime @default(now())
}

model Senaryo {
  id            String   @id @default(cuid())
  ad            String
  aciklama      String?
  hedefModel    String
  tetikleyici   String?
  aktif         Boolean  @default(true)
  olusturanId   String?
  olusturanAd   String?
  olusturmaTar  DateTime @default(now())
  adimlar       SenaryoAdim[]
  akislar       SenaryoAkisi[]
  @@index([hedefModel])
  @@index([aktif])
}
model SenaryoAdim {
  id           String   @id @default(cuid())
  senaryoId    String
  senaryo      Senaryo  @relation(fields: [senaryoId], references: [id], onDelete: Cascade)
  sira         Int
  ad           String
  aciklama     String?
  panel        String
  rol          String?
  aksiyon      String
  sartFieldYol String?
  olusturmaTar DateTime @default(now())
  akisAdimlari SenaryoAkisiAdim[]
  @@index([senaryoId, sira])
}
model SenaryoAkisi {
  id             String   @id @default(cuid())
  senaryoId      String
  senaryo        Senaryo  @relation(fields: [senaryoId], references: [id])
  baslik         String
  hedefModel     String
  hedefId        String?
  durum          String   @default("Aktif")
  baslayanId     String?
  baslayanAd     String?
  aktifSira      Int      @default(1)
  baslamaTar     DateTime @default(now())
  bitirmeTar     DateTime?
  notlar         String?
  adimlar        SenaryoAkisiAdim[]
  @@index([durum])
  @@index([senaryoId])
  @@index([hedefModel, hedefId])
}
model SenaryoAkisiAdim {
  id                String    @id @default(cuid())
  akisId            String
  akis              SenaryoAkisi @relation(fields: [akisId], references: [id], onDelete: Cascade)
  adimId            String
  adim              SenaryoAdim  @relation(fields: [adimId], references: [id])
  sira              Int
  durum             String    @default("Beklemede")
  yapanKullaniciId  String?
  yapanAd           String?
  yapanPanel        String?
  yapilanTar        DateTime?
  notlar            String?
  olusturmaTar      DateTime  @default(now())
  @@index([akisId, sira])
  @@index([durum])
}
